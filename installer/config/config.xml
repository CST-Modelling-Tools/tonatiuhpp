<?xml version="1.0" encoding="UTF-8"?>
<Installer>
  <!-- Basic Qt Installer Framework metadata for Tonatiuh++. -->
  <Name>Tonatiuh++</Name>
  <!-- Rendered from source/CMakeLists.txt by installer/create_installer.py. -->
  <Version>@TONATIUHPP_VERSION@</Version>
  <Title>Tonatiuh++ Installer</Title>
  <Publisher>Tonatiuh++ Project</Publisher>

  <!-- Default target path mirrors current CMake install prefix behavior. -->
  <TargetDir>@HomeDir@/tonatiuhpp</TargetDir>

  <!-- Rendered by installer/create_installer.py for the current platform. -->
  <RemoteRepositories>
    <Repository>
      <Url>@TONATIUHPP_IFW_REPOSITORY_URL@</Url>
      <Enabled>1</Enabled>
      <DisplayName>Tonatiuh++ Updates</DisplayName>
    </Repository>
  </RemoteRepositories>
</Installer>
